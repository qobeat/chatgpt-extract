# Copy to .env (gitignored) and edit for your machine:
#   cp .env.example .env

VENV_DIR="${HOME}/.venvs/chatgpt-extract"
RECONSTRUCTOR_DATA_ROOT="${HOME}/chatgpt-reconstructor-data"

# --- Optional cloud LLM providers, token-exact API billing (Stage 4) ---
# Leave unset to use the local Ollama provider ($0). Never commit real keys.
# These are pay-per-token APIs and are NOT covered by ChatGPT/Claude plans.
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# CURSOR_API_KEY=""

# --- Subscription CLI providers (use your existing plans, not API billing) ---
# These drive your locally-installed, signed-in CLIs so Stage 4 draws on your
# plan/quota instead of per-token API charges. Override the binaries only if the
# CLI is not on PATH under its default name.
# Cursor Pro  -> --provider cursor : run `agent login` first.
# CURSOR_AGENT_BIN="cursor-agent"
# ChatGPT Pro -> --provider codex  : run `codex login` (Sign in with ChatGPT).
# CODEX_BIN="codex"
# Claude Pro  -> --provider claude : run `claude setup-token`, paste the token below.
# CLAUDE_BIN="claude"
# CLAUDE_CODE_OAUTH_TOKEN=""   # from `claude setup-token`; keep ANTHROPIC_API_KEY unset
