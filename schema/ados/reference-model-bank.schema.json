{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ados.dev/schemas/reference-model-bank.schema.json",
  "title": "ADOS Archetype and Domain Reference Model Bank",
  "description": "Reusable models that contribute delivery templates, refinement questions, coordinate seeds, evidence patterns, and failure modes without silently changing the Project Goal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bank_id",
    "bank_version",
    "models"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "bank_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "bank_version": {
      "type": "integer",
      "minimum": 1
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "model_id",
          "model_type",
          "name",
          "definition",
          "classification_ref",
          "scope_exclusions",
          "goal_refinement_questions",
          "objective_refinement_questions",
          "delivery_templates",
          "coordinate_seeds",
          "expected_evidence_patterns",
          "failure_modes"
        ],
        "properties": {
          "model_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "model_type": {
            "enum": [
              "archetype",
              "domain_pair"
            ]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": "string",
            "minLength": 1
          },
          "classification_ref": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "scope_exclusions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          },
          "goal_refinement_questions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "objective_refinement_questions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "delivery_templates": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          },
          "coordinate_seeds": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          },
          "expected_evidence_patterns": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          },
          "failure_modes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          }
        }
      }
    }
  },
  "schema_version": "0.8.20"
}
