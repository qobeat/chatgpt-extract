{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ados.dev/schemas/project-geometry.schema.json",
  "title": "ADOS Project Geometry",
  "description": "Durable delivery-centric Project Meaning Space. Objectives remain governance concepts; Project Coordinates are finalized from material Deliveries, classifications, Requirements, evidence expectations, and reference quality models.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "geometry_id",
    "geometry_version",
    "project_ref",
    "goal_ref",
    "objective_refs",
    "classifications",
    "deliveries",
    "project_coordinates",
    "vectors",
    "revision"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0"
    },
    "geometry_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "geometry_version": {
      "type": "integer",
      "minimum": 1
    },
    "project_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "goal_ref": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "objective_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "classifications": {
      "$ref": "#/$defs/classifications"
    },
    "deliveries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectDelivery"
      },
      "minItems": 1
    },
    "project_coordinates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectCoordinate"
      },
      "minItems": 1
    },
    "vectors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/vectorDefinition"
      },
      "minItems": 1
    },
    "revision": {
      "$ref": "#/$defs/revision"
    }
  },
  "$defs": {
    "domainPairRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain_ref"
      ],
      "properties": {
        "domain_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "subdomain_ref": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "classifications": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary_archetype_ref",
        "secondary_archetype_refs",
        "primary_domain_pair",
        "secondary_domain_pairs"
      ],
      "properties": {
        "primary_archetype_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "secondary_archetype_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "primary_domain_pair": {
          "$ref": "#/$defs/domainPairRef"
        },
        "secondary_domain_pairs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/domainPairRef"
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "sourceRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "goal_refs",
        "objective_refs",
        "archetype_refs",
        "domain_pair_refs",
        "requirement_refs",
        "intent_refs"
      ],
      "properties": {
        "goal_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "objective_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "archetype_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "domain_pair_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "requirement_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "intent_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        }
      }
    },
    "projectDelivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "delivery_id",
        "name",
        "description",
        "delivery_role",
        "materiality",
        "materiality_rationale",
        "boundary_level",
        "process_evidence_materiality",
        "source_refs",
        "archetype_refs",
        "domain_pair_refs",
        "acceptance_context",
        "coordinate_refs",
        "dependency_refs",
        "reference_class"
      ],
      "properties": {
        "delivery_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "delivery_role": {
          "enum": [
            "primary",
            "secondary",
            "integration"
          ]
        },
        "materiality": {
          "enum": [
            "material",
            "supporting"
          ]
        },
        "source_refs": {
          "$ref": "#/$defs/sourceRefs"
        },
        "archetype_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "domain_pair_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "acceptance_context": {
          "type": "string",
          "minLength": 1
        },
        "coordinate_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dependency_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "reference_class": {
          "$ref": "#/$defs/referenceClass"
        },
        "boundary_level": {
          "enum": [
            "product_surface",
            "independently_accepted_subsystem",
            "evidence_bearing_component",
            "supporting_artifact"
          ],
          "description": "Highest delivery-boundary ladder level that preserves independent acceptance without hiding material evidence or gates."
        },
        "materiality_rationale": {
          "type": "string",
          "minLength": 1
        },
        "process_evidence_materiality": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "is_material",
            "rationale"
          ],
          "properties": {
            "is_material": {
              "type": "boolean"
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "coordinate_budget_rationale": {
          "type": "string",
          "minLength": 1,
          "description": "Delivery-level justification for using fewer than three or more than seven active Coordinates, or for another explicit coordinate-compaction decision."
        }
      }
    },
    "referenceClass": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "benchmark_source_refs",
        "applicability_notes"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "benchmark_source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "applicability_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "delivery_state",
        "required_conditions",
        "required_evidence",
        "exclusion_conditions"
      ],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "multipleOf": 10
        },
        "delivery_state": {
          "type": "string",
          "minLength": 1
        },
        "required_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "required_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "exclusion_conditions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    },
    "measurementContract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "quality_question",
        "native_value_type",
        "native_unit",
        "measurement_method",
        "evidence_requirements",
        "scale_type",
        "arithmetic_policy",
        "anchor_policy",
        "anchors",
        "unknown_policy",
        "target_definition"
      ],
      "properties": {
        "mode": {
          "enum": [
            "formula",
            "anchored",
            "hybrid"
          ]
        },
        "quality_question": {
          "type": "string",
          "minLength": 1
        },
        "native_value_type": {
          "enum": [
            "number",
            "integer",
            "boolean",
            "category",
            "evidence_judgment"
          ]
        },
        "native_unit": {
          "type": "string",
          "minLength": 1
        },
        "measurement_method": {
          "type": "string",
          "minLength": 1
        },
        "evidence_requirements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "scale_type": {
          "enum": [
            "formula_interval",
            "calibrated_interval",
            "anchored_ordinal"
          ]
        },
        "arithmetic_policy": {
          "enum": [
            "aggregation_allowed",
            "ordering_only",
            "policy_index"
          ]
        },
        "anchor_policy": {
          "enum": [
            "deciles",
            "custom"
          ]
        },
        "anchors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/anchor"
          },
          "minItems": 2,
          "maxItems": 11
        },
        "unknown_policy": {
          "const": "null_not_zero"
        },
        "target_definition": {
          "type": "string",
          "minLength": 1
        },
        "observation_contract": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "rationale"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            },
            "benchmark_or_reference_baseline": {
              "type": [
                "string",
                "null"
              ]
            },
            "evaluation_population_or_scenario_set": {
              "type": [
                "string",
                "null"
              ]
            },
            "observation_window": {
              "type": [
                "string",
                "null"
              ]
            },
            "minimum_sample_size_or_run_count": {
              "type": [
                "string",
                "null"
              ]
            },
            "confidence_or_uncertainty_rule": {
              "type": [
                "string",
                "null"
              ]
            },
            "cost_latency_or_resource_assumptions": {
              "type": [
                "string",
                "null"
              ]
            },
            "refresh_or_expiration_policy": {
              "type": [
                "string",
                "null"
              ]
            },
            "known_out_of_scope_conditions": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "projectCoordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coordinate_id",
        "name",
        "definition",
        "scope",
        "vector_ref",
        "owner_vector_ref",
        "owner_delivery_ref",
        "delivery_refs",
        "measures",
        "does_not_measure",
        "distinct_from",
        "source_refs",
        "best_in_class_basis",
        "measurement_contract",
        "status",
        "coordinate_kind",
        "interaction_refs"
      ],
      "properties": {
        "coordinate_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "definition": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "enum": [
            "delivery_local",
            "cross_delivery",
            "project_wide"
          ]
        },
        "vector_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "delivery_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "measures": {
          "type": "string",
          "minLength": 1
        },
        "does_not_measure": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "distinct_from": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "source_refs": {
          "$ref": "#/$defs/sourceRefs"
        },
        "best_in_class_basis": {
          "$ref": "#/$defs/referenceClass"
        },
        "measurement_contract": {
          "$ref": "#/$defs/measurementContract"
        },
        "status": {
          "enum": [
            "candidate",
            "active"
          ]
        },
        "coordinate_kind": {
          "enum": [
            "scoring",
            "guard",
            "diagnostic"
          ],
          "description": "Whether the coordinate contributes to score, guards/preserves acceptance, or supports repair/monitoring only."
        },
        "owner_delivery_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "owner_vector_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "interaction_refs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "interaction_type",
              "coordinate_ref",
              "rationale"
            ],
            "properties": {
              "interaction_type": {
                "enum": [
                  "depends_on",
                  "supports",
                  "trades_off_with",
                  "must_not_regress_with",
                  "invalidates_if_failed"
                ]
              },
              "coordinate_ref": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
              },
              "rationale": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "vectorDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vector_id",
        "vector_type",
        "name",
        "delivery_ref",
        "coordinate_order",
        "ideal_target_rule"
      ],
      "properties": {
        "vector_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "vector_type": {
          "enum": [
            "delivery",
            "integration",
            "project_wide"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "delivery_ref": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
            },
            {
              "type": "null"
            }
          ]
        },
        "coordinate_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "ideal_target_rule": {
          "const": "each_active_coordinate_equals_100"
        }
      }
    },
    "revision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "supersedes_geometry_version",
        "revision_intent_refs",
        "revision_summary"
      ],
      "properties": {
        "supersedes_geometry_version": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "revision_intent_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
          },
          "uniqueItems": true,
          "default": []
        },
        "revision_summary": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "schema_version": "0.8.20"
}
