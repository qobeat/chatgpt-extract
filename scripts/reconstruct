#!/usr/bin/env bash
# reconstruct — backward-compatible alias for `gpt` (now lives under scripts/).
# The primary entrypoint is `./gpt` at the repo root; this forwards all
# arguments to it so existing scripts and muscle memory keep working. Invoke as
# `./scripts/reconstruct ...`.
set -euo pipefail
REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec "$REPO_DIR/gpt" "$@"
